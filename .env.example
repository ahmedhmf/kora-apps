# ─── Database ──────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=surveydb
DB_USER=surveyuser
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ─── Admin Credentials ─────────────────────────────────────────────────────────
# Username for the admin account
ADMIN_USERNAME=admin

# bcrypt hash of the admin password.
# Generate it by running: node generate-hash.js
# Then paste the output here:
ADMIN_PASSWORD_HASH=$2b$12$REPLACE_WITH_YOUR_BCRYPT_HASH_HERE

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random secret:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRES_IN=8h

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Set to your domain once live. Use '*' only for local development.
CORS_ORIGIN=https://yourdomain.com
